<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:M3u8Downloader_H.Gui.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:Class="M3u8Downloader_H.Gui.Views.MainWindow"
        xmlns:views="using:M3u8Downloader_H.Demo.Views"
        xmlns:viewmodels="using:M3u8Downloader_H.Demo.ViewModel"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="M3u8Downloader_H.Gui">

    <ContentControl>
		<Border Padding="10" >
			<ContentPresenter Content="{Binding MainView}" />
        </Border>
    </ContentControl>

</Window>
